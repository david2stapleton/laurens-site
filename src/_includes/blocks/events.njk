{% for event in block.events %}
<div class="event-item{% if event.image_side == 'right' %} event-image-right{% endif %}">
  {% if event.image %}
  <div class="event-image">
    <img src="{{ event.image }}" alt="{{ event.title }}">
  </div>
  {% endif %}
  <div class="event-details">
    <h3 class="event-title">{{ event.title }}</h3>
    {% if event.date %}<p class="event-meta event-date">{{ event.date }}</p>{% endif %}
    {% if event.time %}<p class="event-meta event-time">{{ event.time }}</p>{% endif %}
    {% if event.location %}<p class="event-meta event-location">{{ event.location }}</p>{% endif %}
    {% if event.description %}<p class="event-description">{{ event.description }}</p>{% endif %}
    {% if event.link_url %}<a href="{{ event.link_url }}" class="btn" target="_blank" rel="noopener">{{ event.link_label or "Get Tickets" }}</a>{% endif %}
  </div>
</div>
{% endfor %}
