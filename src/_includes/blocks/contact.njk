<div class="contact-grid">
  <div class="contact-form-wrapper">
    <form class="contact-form" id="contact-form" action="https://formsubmit.co/73d6a7aab01a74f88648c387323e2036" method="POST">
      <input type="hidden" name="_subject" value="New contact from {{ site.design.site_name }}">
      <input type="hidden" name="_captcha" value="false">
      <input type="text" name="_honey" style="display:none">
      <div class="form-group">
        <input type="text" id="name" name="name" placeholder="Name" required>
      </div>
      <div class="form-group">
        <input type="email" id="email" name="email" placeholder="Email" required>
      </div>
      <div class="form-group">
        <textarea id="message" name="message" rows="5" placeholder="Message" required></textarea>
      </div>
    </form>
    <button type="submit" form="contact-form" class="btn">Send Message</button>
  </div>
  {% if block.image %}
  <div class="contact-photo">
    <img src="{{ block.image }}" alt="">
  </div>
  {% endif %}
</div>
