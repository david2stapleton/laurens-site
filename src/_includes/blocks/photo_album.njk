{% if block.title or block.credits %}
<div class="photo-album-header">
  {% if block.title %}
    <p class="photo-album-title">{{ block.title | markdownInline | safe }}</p>
  {% endif %}
  {% if block.credits %}
    <p class="photo-album-credits">{{ block.credits }}</p>
  {% endif %}
</div>
{% endif %}
<div class="photo-grid photo-grid-{{ block.columns | default(3) }}">
  {% for item in block.images %}
    <figure class="photo-grid-item">
      <img src="{{ item.image }}" alt="{{ item.caption | default('') }}" style="object-position: {{ item.focus | default('center') }}">
      {% if item.caption %}
        <figcaption style="text-align: {{ site.design.caption_align | default('center') }}">{{ item.caption | markdown | safe }}</figcaption>
      {% endif %}
    </figure>
  {% endfor %}
</div>
